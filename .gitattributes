# Normalize line endings — Swift/text files are LF in the repo regardless of OS.
* text=auto eol=lf

# Explicit text types
*.swift    text eol=lf
*.plist    text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.xcstrings text eol=lf
*.entitlements text eol=lf
.gitignore text eol=lf
.editorconfig text eol=lf

# Binary assets — never touch
*.png binary
*.jpg binary
*.jpeg binary
*.pdf binary
